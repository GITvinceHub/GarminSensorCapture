<?xml version="1.0"?>
<!--
  GarminSensorCapture — Connect IQ Store manifest
  App UUID:  a3b4c5d6-e7f8-1234-abcd-ef0123456789
             (register this UUID on developer.garmin.com → "Add App" to get a storeId)
  Developer: [YOUR NAME / ORGANIZATION]
-->
<iq:manifest xmlns:iq="http://www.garmin.com/xml/connectiq" version="1">
    <iq:application entry="GarminSensorApp"
                    id="a3b4c5d6e7f81234abcdef0123456789"
                    launcherIcon="@Drawables.LauncherIcon"
                    minSdkVersion="3.3.0"
                    name="@Strings.app_name"
                    type="watch-app"
                    version="1.0.1">

        <!-- ─── Supported devices ──────────────────────────────────── -->
        <!-- fēnix 7 series  (260×260 round MIP) -->
        <!-- fēnix 8 series  (454×454 round AMOLED) -->
        <iq:products>
            <!-- fēnix 7 -->
            <iq:product id="fenix7"/>
            <iq:product id="fenix7s"/>
            <iq:product id="fenix7x"/>
            <iq:product id="fenix7pro"/>
            <iq:product id="fenix7spro"/>
            <iq:product id="fenix7xpro"/>
            <!-- fēnix 8 -->
            <iq:product id="fenix843mm"/>
            <iq:product id="fenix847mm"/>
            <iq:product id="fenix8pro47mm"/>
            <iq:product id="fenix8solar47mm"/>
            <iq:product id="fenix8solar51mm"/>
        </iq:products>

        <!-- ─── Required permissions ──────────────────────────────── -->
        <!--
          Conformance GIQ-006 (cf. SPECIFICATION.md §13.3 V1) :
          data minimization — on ne déclare QUE ce qui est réellement utilisé
          par le code source. v2.0.0-from-spec n'utilise ni FitContributor,
          ni UserProfile, ni SensorHistory (ces permissions sont listées dans
          l'historique §12.2 comme candidats à réintroduction ultérieure).
        -->
        <iq:permissions>
            <iq:uses-permission id="Sensor"/>         <!-- IMU (accel/gyro/mag) via registerSensorDataListener -->
            <iq:uses-permission id="Positioning"/>    <!-- GPS via Position.enableLocationEvents            -->
            <iq:uses-permission id="Communications"/> <!-- BLE phone-app messaging                          -->
        </iq:permissions>

        <!-- ─── Store languages ──────────────────────────────────── -->
        <iq:languages>
            <iq:language>eng</iq:language>
            <iq:language>fra</iq:language>
        </iq:languages>

        <!-- Required by the Connect IQ Store schema, even when empty. -->
        <iq:barrels/>

    </iq:application>
</iq:manifest>
