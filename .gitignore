# =============================================================================
# .gitignore — GarminSensorCapture
# =============================================================================

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
.env
.venv
venv/
env/
pip-wheel-metadata/
*.whl

# Pytest
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml
*.cover

# Jupyter
.ipynb_checkpoints/

# ── Python Analysis Output ────────────────────────────────────────────────────
03_python_analysis/output/
03_python_analysis/**/*.csv
03_python_analysis/**/*.png
03_python_analysis/**/*.json
!03_python_analysis/sample_data/sample_session.jsonl

# ── Connect IQ / Monkey C ─────────────────────────────────────────────────────
01_watch_app_connectiq/bin/
01_watch_app_connectiq/build/
01_watch_app_connectiq/output/
01_watch_app_connectiq/.settings/
*.prg
*.iq
*.debug.iq
01_watch_app_connectiq/.project
01_watch_app_connectiq/.classpath

# Developer key (NEVER commit)
01_watch_app_connectiq/developer_key
01_watch_app_connectiq/*.pem
01_watch_app_connectiq/*.der

# ── Android ───────────────────────────────────────────────────────────────────
02_android_companion/.gradle/
02_android_companion/build/
02_android_companion/app/build/
02_android_companion/local.properties
02_android_companion/*.iml
02_android_companion/.idea/

# Android keystore (NEVER commit)
02_android_companion/*.jks
02_android_companion/*.keystore
02_android_companion/keystore.properties

# Connect IQ AAR (binary, redistribute separately)
02_android_companion/app/libs/ConnectIQ.aar

# Generated APKs/AABs
02_android_companion/**/*.apk
02_android_companion/**/*.aab

# ── Captured Data ─────────────────────────────────────────────────────────────
# Real session data should not be committed (can be large)
**/*_session_*.jsonl
!03_python_analysis/sample_data/sample_session.jsonl
!02_android_companion/sample_output/sample_session.jsonl

# ── Release Archives ──────────────────────────────────────────────────────────
06_release/*.zip
06_release/*.tar.gz
06_release/*.tar.bz2

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editors ───────────────────────────────────────────────────────────────────
.idea/
*.swp
*.swo
*~
.vscode/
*.sublime-workspace
*.sublime-project

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Temp ─────────────────────────────────────────────────────────────────────
*.tmp
*.bak
*.orig

# ── Claude Code (local tooling config, not project code) ─────────────────────
.claude/
